# 构建加速镜像源（CI / Docker 本地构建可用）
# Debian/apt 镜像主机名，不带 https:// 前缀
DEBIAN_MIRROR=mirrors.aliyun.com
# Python 包索引镜像
PYPI_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
# npm 镜像
NPM_REGISTRY=https://registry.npmmirror.com

# 微信支付配置（平台公钥模式 - 2024年9月后新账户）
# 获取方式：登录 https://pay.weixin.qq.com/
WECHAT_APPID=wxXXXXXXXXXXXXXXXXXX                     # 应用ID - 账户中心 → 个人信息 → AppID账号
WECHAT_MCH_ID=1633248199                              # 商户号 - 账户中心 → 商户信息
WECHAT_CERT_SERIAL_NO=70AF8D097B947D3E69A63F2E7BCDAA256C448102  # 商户API证书序列号 - 从apiclient_cert.pem获取
WECHAT_API_KEY=e2NkiRppqizQWeLfxK9bLeZ2h752QdYL      # APIv3密钥（32位）- 账户中心 → API安全 → APIv3密钥
WECHAT_KEY_PATH=./certs/apiclient_key.pem             # 商户私钥文件路径 - 从微信支付商户平台下载证书
WECHAT_NOTIFY_URL=http://localhost:8888/api/v1/payment/callback/wechat  # 支付回调URL - 生产环境使用HTTPS
WECHAT_PUBLIC_KEY=./certs/pub_key.pem                 # 微信支付平台公钥文件路径 - 账户中心 → API安全 → 平台公钥
WECHAT_PUBLIC_KEY_ID=PUB_KEY_ID_0116332481992026032700182307002406  # 微信支付平台公钥ID - 显示在平台公钥页面

# 支付宝配置
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
